$(() => {
  const GEO_OPTIONS = {
    enableHighAccuracy: true,
    timeout: 30000,
    maximumAge: 0
  };

  const GEO_LOW_ACCURACY_OPTIONS = {
    enableHighAccuracy: false,
    timeout: 15000,
    maximumAge: 0
  };

  const hidePopup = () => $('#popup').hide();

  const setImages = (driverPath, smellPath, cleanPath) => {
    $('#driver-score').empty().prepend(`<img id="Driver_img" src="${driverPath}">`);
    $('#smell-score').empty().prepend(`<img id="Smell_img" src="${smellPath}">`);
    $('#clean-score').empty().prepend(`<img id="Clean_img" src="${cleanPath}">`);
  };

  const setDefaultImages = () => {
    const path = '<%= asset_path "Question_mark.png" %>';
    setImages(path, path, path);
  };

  const distanceBetweenPoints = (a, b) =>
    Math.sqrt((a.latitude - b.latitude) ** 2 + (a.longitude - b.longitude) ** 2);

  const sortVehiclesByRoute = (data) =>
    data.items.map(item => {
      let i = 0, num = 0;
      while (item.route_id[i] >= '0' && item.route_id[i] <= '9') {
        num = num * 10 + Number(item.route_id[i++]);
      }
      return { routeId: item.route_id, routeNum: num };
    }).sort((a, b) => a.routeNum !== b.routeNum
      ? a.routeNum - b.routeNum
      : a.routeId.localeCompare(b.routeId));

  const uniqueRouteIds = (vehicles) => [...new Set(vehicles.map(v => v.routeId))];

  const getAverages = (name) => {
    $.ajax({ url: `/munis/${name}/average` })
      .done(content => {
        $('#route_name').val(name);
        document.getElementById('route_name_tag').textContent = name;
        $('#submit-btn').removeAttr('disabled').prop('disabled', false);
        try {
          <% image_names = [] %>
          <% ["Driver", "Smell", "Clean"].each { |attr| 5.times { |num| image_names.push("#{attr}_0#{num + 1}.png") } } %>
          const imagePaths = <%= image_names.map { |img| asset_path(img) }.to_json %>;
          if (content && content.avg_driver_rating != null) {
            setImages(
              imagePaths[content.avg_driver_rating - 1],
              imagePaths[content.avg_smell_rating + 5 - 1],
              imagePaths[content.avg_clean_rating + 10 - 1]
            );
          } else {
            setDefaultImages();
          }
        } catch (e) {
          setDefaultImages();
        }
      });
  };

  const processBusLocations = (coords, onComplete) => {
    $.ajax({ url: '/munis/vehicles' })
      .done(data => {
        const vehicles = data.items;
        if (!vehicles || !vehicles.length) return;
        vehicles.sort((a, b) => distanceBetweenPoints(a, coords) - distanceBetweenPoints(b, coords));
        // TODO: restore distance check for production (< 0.003 degrees ≈ 300m)
        getAverages(vehicles[0].route_id);
        onComplete(vehicles);
      })
      .fail((xhr, status, err) => console.warn(`Vehicles request failed: ${status}`, err));
  };

  const initMap = (coords, vehicles) => {
    const map = new google.maps.Map(document.getElementById('map'), {
      center: { lat: coords.latitude, lng: coords.longitude },
      zoom: 15
    });
    vehicles.forEach(vehicle => {
      const marker = new google.maps.Marker({
        position: new google.maps.LatLng(vehicle.latitude, vehicle.longitude),
        map
      });
      const content = document.createElement('a');
      content.textContent = vehicle.route_id;
      content.addEventListener('click', () => {
        hidePopup();
        getAverages(vehicle.route_id);
      });
      const infowindow = new google.maps.InfoWindow();
      marker.addListener('click', () => {
        infowindow.setContent(content);
        infowindow.open(map, marker);
      });
    });
  };

  const onGeolocationSuccess = (pos) => {
    const coords = pos.coords;
    processBusLocations(coords, vehicles => {
      document.getElementById('route_name_tag').addEventListener('click', () => {
        $('#popup').show();
        initMap(coords, vehicles);
      });
    });
  };

  const onGeolocationError = (err) => {
    console.warn(`ERROR(${err.code}): ${err.message}`);
    if (err.code === 3) {
      navigator.geolocation.getCurrentPosition(onGeolocationSuccess, err2 => {
        console.warn(`Low accuracy fallback failed (${err2.code}): ${err2.message}`);
      }, GEO_LOW_ACCURACY_OPTIONS);
    }
  };

  // Init
  hidePopup();

  document.getElementById('popup').addEventListener('click', hidePopup);
  document.getElementById('popup-1').addEventListener('click', e => e.stopPropagation());

  ['range_smell', 'range_driver', 'range_clean'].forEach(id => {
    const el = document.getElementById(id);
    const roundValue = () => { el.value = Math.round(el.value); };
    el.addEventListener('mouseup', roundValue);
    el.addEventListener('touchend', roundValue);
  });

  if (!navigator.geolocation) {
    console.warn('Geolocation is not supported (check HTTPS).');
  } else {
    navigator.geolocation.getCurrentPosition(onGeolocationSuccess, onGeolocationError, GEO_OPTIONS);
  }
});
