<div class="slider row">
  <div class="slider__icon-col col-xs-3">
    <%= image_tag "#{item.capitalize}_01.png", class: "slider__icon", alt: "#{item} low" %>
  </div>
  <div class="slider__label-col col-xs-6">
    <h3 class="slider__label"><%= item.capitalize %></h3>
  </div>
  <div class="slider__icon-col col-xs-3">
    <%= image_tag "#{item.capitalize}_05.png", class: "slider__icon", alt: "#{item} high" %>
  </div>
  <div class="row">
    <div class="col-xs-12">
      <input class="slider__input" id="<%= "range_#{item}" %>" type="range" name="<%= "#{item}_rating" %>" min="1" value="1" step="0.05" max="5">
    </div>
  </div>
</div>
