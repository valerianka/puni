<header class="page-header">
  <div class="bus">
    <%= render 'shared/flash_messages' if flash.any? %>
    <%= image_tag "puni_logo.png", width: "125", alt: "Puni logo", class: "page-header__logo" %>
    <%= render 'shared/bus' %>
  </div>
</header>

<main class="container rating-form-container">
  <h1 class="rating-form-container__title">MUNI Stinks....Rate Your Ride!</h1>

  <%= form_tag("/leaderboard", method: :post, class: "rating-form") do %>
    <%= hidden_field_tag(:route_name, 1, id: "route_name") %>

    <%= render 'shared/slider', item: "smell" %>
    <%= render 'shared/slider', item: "clean" %>
    <%= render 'shared/slider', item: "driver" %>

    <div class="rating-form__story">
      <h3 class="rating-form__story-label"><label for="comment">Horror story</label></h3>
      <%= text_area_tag(:comment, "", rows: 5, class: "rating-form__story-input form-control") %>
    </div>

    <%= submit_tag "Submit your rating", class: "rating-form__submit btn btn-primary btn-lg btn-block", disabled: true, id: "submit-btn" %>
  <% end %>

  <hr>
  <%= render 'shared/footer' %>
</main>

<div class="popup" id="popup">
  <div class="popup__content" id="popup-1">
    <div class="popup__map" id="map"></div>
  </div>
</div>

<script async defer src="https://maps.googleapis.com/maps/api/js?key=<%= ENV['GOOGLE_MAPS_API_KEY'] %>"></script>
