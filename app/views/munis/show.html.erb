<header class="page-header">
  <div class="award-display">
    <%= image_tag "puni-award.png", alt: "Puni award", class: "award-display__image" %>
    <h3 class="award-display__title">PUNI Awards</h3>
  </div>
</header>

<main class="container leaderboard">
  <%= image_tag "puni_logo.png", width: "100", alt: "Puni logo", class: "leaderboard__logo" %>
  <h2 class="leaderboard__title">Stink Champs</h2>
  <div class="row leaderboard__winners">
    <%= render 'shared/stink_winner', winner: @munis.first if @munis %>
    <%= render 'shared/stink_winner', winner: @munis.second if @munis&.second %>
    <%= render 'shared/stink_winner', winner: @munis.third if @munis&.third %>
  </div>
  <hr>
  <%= render 'shared/footer' %>
</main>
