#!/usr/bin/env bash
set -euo pipefail

# Use Homebrew Ruby 4.0 which matches the project's bundle
RUBY="/opt/homebrew/Cellar/ruby/4.0.2/bin/ruby"
export PATH="/opt/homebrew/Cellar/ruby/4.0.2/bin:$PATH"
export BUNDLE_PATH=.
export SSL_CERT_FILE=/etc/ssl/cert.pem
export DISABLE_SPRING=1

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "🧪 Running unit + integration tests..."

if ! bundle exec rails test; then
  echo ""
  echo "❌ Tests failed — push aborted."
  echo "   Fix the failing tests, then push again."
  exit 1
fi

echo "🖥️  Running system (UI) tests..."

if ! bundle exec rails test:system; then
  echo ""
  echo "❌ System tests failed — push aborted."
  echo "   Fix the failing tests, then push again."
  exit 1
fi

echo "✅ All tests passed"
